# focus window
ctrl + alt + cmd - left : yabai -m window --focus west
ctrl + alt + cmd - right : yabai -m window --focus east
ctrl + alt + cmd - up : yabai -m window --focus north
ctrl + alt + cmd - down : yabai -m window --focus south

# stack focus
ctrl + alt + cmd - j : yabai -m window --focus stack.next
ctrl + alt + cmd - k : yabai -m window --focus stack.prev

# swap managed window
ctrl + alt + cmd + shift - left : yabai -m window --swap north
ctrl + alt + cmd + shift - right : yabai -m window --swap east
ctrl + alt + cmd + shift - up : yabai -m window --swap north
ctrl + alt + cmd + shift - down : yabai -m window --swap south

# stack swap
ctrl + alt + cmd - j : yabai -m window --swap stack.next
ctrl + alt + cmd - k : yabai -m window --swap stack.prev

ctrl + alt + cmd - s : yabai -m window --stack next
ctrl + alt + cmd + shift - s : yabai -m window --warp stack.prev

# toggle layout between stack and bsp
ctrl + alt + cmd - l : (yabai -m query --spaces --space | jq -e 'select(.type == "bsp").index') && yabai -m space --layout stack || yabai -m space --layout bsp

# focus monitor
ctrl - left : yabai -m display --focus prev
ctrl - right : yabai -m display --focus next
ctrl + shift - left : yabai -m space --focus prev
ctrl + shift - right : yabai -m space --focus next

# toggle window zoom
ctrl + alt + cmd - f : yabai -m window --toggle zoom-fullscreen
ctrl + alt + cmd + shift - f : yabai -m window --toggle native-fullscreen

# toggle window split type
# alt - e : yabai -m window --toggle split

# float / unfloat window and center on screen
ctrl + alt + cmd - t : yabai -m window --toggle float;\
                       yabai -m window --grid 4:4:1:1:2:2

