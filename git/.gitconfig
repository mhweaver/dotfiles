[core]
	preloadindex = true
	editor = nvim
	excludesfile = /Users/mweaver/.gitignore_global
[user]
	name = "mhweaver"
	email = "mhweaver@gmail.com"
[includeIf "gitdir:~/scripts/"]
	path = ~/.gitconfig-work
[includeIf "gitdir:~/code/"]
	path = ~/.gitconfig-work
[push]
	default = simple
	autoSetupRemote = true
[help]
	autocorrect = prompt
[alias]
	last = cat-file commit HEAD
	up = pull --rebase=merges --autostash --all
	unstage = reset HEAD --
[color]
	branch = auto
	diff = auto
	interactive = auto
	pager = true
	status = auto
[log]
	date = local
[init]
	templatedir = ~/.git-templates
[status]
	submodulesummary = true
[pull]
	rebase = merges
[rerere]
	enabled = true
	autoupdate = true
; [credential]
;	helper = 1password -t -q
;	helper = cache --timeout 86400
[svn]
	pushmergeinfo = true
[diff]
	algorithm = histogram
	renames = true
	colorMoved = plain
	mnemonicPrefix = true
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[column]
	ui = auto
[branch]
	sort = -committerdate
[tag]
	sort = version:refname
[fetch]
	all = true
[commit]
	verbose = true
