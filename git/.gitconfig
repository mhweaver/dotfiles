[core]
	preloadindex = true
	editor = vim
[user]
	name = "mhweaver"
	email = "mhweaver@gmail.com"
[includeIf "gitdir:~/scripts/"]
	path = ~/.gitconfig-work
[includeIf "gitdir:~/code/"]
	path = ~/.gitconfig-work
[push]
	default = simple
[help]
	autocorrect = 1
[alias]
	last = cat-file commit HEAD
	up = pull --rebase=merges --autostash --all
	unstage = reset HEAD --
[color]
	branch = auto
	diff = auto
	interactive = auto
	pager = true
	status = auto
[log]
	date = local
[init]
	templatedir = ~/.git-templates
[status]
	submodulesummary = true
[pull]
	rebase = preserve
[rerere]
	enabled = true
	autoupdate = true
[credential]
	helper = cache --timeout 86400
[svn]
	pushmergeinfo = true
